<% layout('layout') %>

<h1>Edit Blog</h1>

<form action="/blogs/<%= blog._id %>?_method=PUT" method="POST" enctype="multipart/form-data">
    <div class="mb-3">
        <label>Title</label>
        <input type="text" name="blog[title]" value="<%= blog.title %>" class="form-control">
    </div>

    <div class="mb-3">
            <label for="image" class="form-label">Upload New Image</label>
            <input name="blog[image]" type="file" class="form-control"/>
    </div>
    <div class="mb-3">
        <label>Content</label>
        <textarea name="blog[content]" rows="5" class="form-control"><%= blog.content %></textarea>
    </div>

    <button class="btn btn-success">Update Blog</button>
</form>
